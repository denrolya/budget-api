# ============================================================================
# Canonical environment template for the backend API.
# Copy this file to .env for local development.
# Keep production values in real server environment variables
# (or, if needed, in uncommitted host-specific files).
#
# IMPORTANT:
# - Never commit real secrets.
# - Use strong unique values for APP_SECRET and API keys.
# ============================================================================

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_to_a_long_random_secret
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Example for MySQL 8.x
DATABASE_URL="mysql://db_user:db_password@127.0.0.1:3306/db_name?serverVersion=8.0"
###< doctrine/doctrine-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_TOKEN_TTL=259200
JWT_PASSPHRASE=change_me
###< lexik/jwt-authentication-bundle ###

###> fixer ###
FIXER_BASE_URL=http://data.fixer.io/api/
FIXER_API_KEY=change_me
###< fixer ###

###> monobank ###
MONOBANK_BASE_URL=https://api.monobank.ua
MONOBANK_API_KEY=change_me
###< monobank ###

###> wise ###
WISE_BASE_URL=https://api.wise.com
WISE_API_KEY=change_me
###< wise ###

###> webhook ###
# Public API base URL used for webhook registration from CLI/deploy jobs.
# Required for: bin/console app:bank:webhooks:refresh
# Example: https://api.example.com
WEBHOOK_BASE_URL=
###< webhook ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> deploy (optional) ###
DEPLOY_HOST=
DEPLOY_USER=
DEPLOY_IDENTITY_FILE=~/.ssh/id_rsa
DEPLOY_BRANCH=master
DEPLOY_PATH=/var/www/api
DEPLOY_KEEP_RELEASES=5
DEPLOY_APP=api
DEPLOY_REPO=
DEPLOY_HTTP_USER=www-data
DB_REMOTE_NAME=
DB_REMOTE_USER=
DB_REMOTE_PASSWORD=
DB_LOCAL_NAME=
DB_LOCAL_USER=
DB_LOCAL_PASSWORD=
###< deploy ###
